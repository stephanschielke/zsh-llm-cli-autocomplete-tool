if success:
    print('')
    print('✅ Model (base+adapter) imported to Ollama! Use zsh-assistant for autocomplete.')
    sys.exit(0)
else:
    print('')
    print('❌ Failed to import model')
    print('   You can try running manually: python -m model_completer.cli --import-to-ollama')
    sys.exit(1)
